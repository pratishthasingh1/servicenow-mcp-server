# ServiceNow Instance URL (e.g. https://yourcompany.service-now.com)
SNOW_INSTANCE_URL=

# Authentication method: "oauth" or "basic"
SNOW_AUTH_METHOD=basic

# ServiceNow credentials
SNOW_USERNAME=
SNOW_PASSWORD=

# OAuth 2.0 settings (required when SNOW_AUTH_METHOD=oauth)
# Register an OAuth app in ServiceNow: System OAuth > Application Registry
SNOW_CLIENT_ID=
SNOW_CLIENT_SECRET=
